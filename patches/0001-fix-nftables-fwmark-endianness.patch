# GL.iNet: nftables fwmark mask bytes must be native-endian (issue #11803).
# Upstream: https://github.com/tailscale/tailscale/issues/11803
# Related PR: https://github.com/tailscale/tailscale/pull/19601
# Remove this patch after the fix is in the Tailscale version we ship.
#
Index: tailscale-1.96.4/util/linuxfw/linuxfw.go
===================================================================
--- tailscale-1.96.4.orig/util/linuxfw/linuxfw.go
+++ tailscale-1.96.4/util/linuxfw/linuxfw.go
@@ -7,6 +7,7 @@
 package linuxfw
 
 import (
+	"encoding/binary"
 	"errors"
 	"fmt"
 	"os"
@@ -79,19 +80,34 @@
 	bypassMarkNum      = tsconst.LinuxBypassMarkNum
 )
 
-// getTailscaleFwmarkMaskNeg returns the negation of TailscaleFwmarkMask in bytes.
+// nftables expressions (Bitwise mask/xor, Cmp data, …) that operate on
+// the packet/conntrack mark expect the 4-byte payload to be in host
+// byte order, since the kernel reads it back as a host-endian uint32.
+// Hard-coding the bytes in big-endian order, as was previously done,
+// produced the wrong mask/mark on little-endian systems (i.e. all of
+// x86_64 and aarch64 in practice): instead of the documented
+// 0x00ff0000/0x00040000 the rules ended up using 0x0000ff00/0x00000400,
+// which both diverges from the iptables backend and silently breaks
+// the connmark save/restore rules that rely on getTailscaleFwmarkMask
+// matching the values written by the iptables/ip rule paths. See
+// https://github.com/tailscale/tailscale/issues/11803.
+//
+// Upstream: https://github.com/tailscale/tailscale/pull/19601 (same fix when merged).
+
+// getTailscaleFwmarkMaskNeg returns the negation of TailscaleFwmarkMask in
+// host-endian bytes, for use as the AND mask in nftables Bitwise expressions.
 func getTailscaleFwmarkMaskNeg() []byte {
-	return []byte{0xff, 0x00, 0xff, 0xff}
+	return binary.NativeEndian.AppendUint32(nil, ^uint32(tsconst.LinuxFwmarkMaskNum))
 }
 
-// getTailscaleFwmarkMask returns the TailscaleFwmarkMask in bytes.
+// getTailscaleFwmarkMask returns the TailscaleFwmarkMask in host-endian bytes.
 func getTailscaleFwmarkMask() []byte {
-	return []byte{0x00, 0xff, 0x00, 0x00}
+	return binary.NativeEndian.AppendUint32(nil, uint32(tsconst.LinuxFwmarkMaskNum))
 }
 
-// getTailscaleSubnetRouteMark returns the TailscaleSubnetRouteMark in bytes.
+// getTailscaleSubnetRouteMark returns the TailscaleSubnetRouteMark in host-endian bytes.
 func getTailscaleSubnetRouteMark() []byte {
-	return []byte{0x00, 0x04, 0x00, 0x00}
+	return binary.NativeEndian.AppendUint32(nil, uint32(tsconst.LinuxSubnetRouteMarkNum))
 }
 
 // checkIPv6ForTest can be set in tests.
